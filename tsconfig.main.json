{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": ".",
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "main.ts",
    "ipc-contract.ts",
    "src/types/import.ts",
    "src/types/transactions.ts"
  ]
}
