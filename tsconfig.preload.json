{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": ".",
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["preload.ts", "ipc-contract.ts", "src/types/import.ts"]
}
